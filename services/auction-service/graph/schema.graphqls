# go get github.com/99designs/gqlgen/internal/imports@v0.17.88
# go get github.com/99designs/gqlgen/api@v0.17.88
# go get github.com/99designs/gqlgen@v0.17.88

# go mod download
# go run github.com/99designs/gqlgen generate
